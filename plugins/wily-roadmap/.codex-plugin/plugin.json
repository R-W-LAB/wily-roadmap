    "category": "Productivity",
    "capabilities": [
      "Interactive",
      "Write"
    ],
    "defaultPrompt": [
      "$wily-init: start or adopt a v3 project",
      "$wily-status: show current v3 task state",
      "$wily-watch: watch v3 task state",
      "$wily-next: show the next ready task",
      "$wily-claim <id>: claim a task",
      "$wily-go <id>: emit custom-workflow goal text",
      "$wily-done <id>: close a verified task",
      "$wily-replan: revise the task list"
    ],
