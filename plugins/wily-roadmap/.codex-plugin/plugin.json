  "interface": {
    "displayName": "Wily Roadmap",
    "shortDescription": "Manage v3 project task lists and local agent workflow state.",
    "longDescription": "Wily Roadmap v3 manages a Project plus a flat list of goal-sized Tasks. It is local-first, approval-first for remote actions, emits custom-workflow goal text without calling external runners, and preserves Codex plugin discovery compatibility.",
